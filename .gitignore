# Build output
build/

# Logs
*.log
build_log.txt
cmake_debug*.log

# VS Code
.vscode/

# ESP-IDF generated
sdkconfig.old

# ESP-IDF managed components (auto-fetched from idf_component.yml + dependencies.lock)
managed_components/

# Local build scratch
_build_tmp.bat

# Claude Code transient state (worktrees, scratch, settings overrides)
.claude/worktrees/
.claude/launch.json
.claude/settings.local.json

# Python bytecode cache (tools/ scripts get run from here and leave
# __pycache__ behind; not worth committing)
__pycache__/
*.pyc
*.pyo

# Accidental Windows-path-as-directory — created when a shell misinterprets
# an unquoted Windows path like `C:\Users\ruuva\workspace\rdm7-sandbox` as
# a relative path, turning it into a literal directory named
# `Usersruuvaworkspacerdm7-sandbox`. Catch the whole pattern.
Usersruuvaworkspace*/
